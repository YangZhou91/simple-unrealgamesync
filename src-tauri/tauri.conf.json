{
  "$schema": "https://raw.githubusercontent.com/nickinchrisclass/tauri/feat-v2/core/tauri-config-schema/schema.json",
  "productName": "Simple UnrealGameSync",
  "version": "1.3.2",
  "identifier": "com.simpleugs.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Simple UnrealGameSync",
        "width": 960,
        "height": 640,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "center": true,
        "decorations": true,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --disable-background-timer-throttling --disable-renderer-backgrounding --disable-backgrounding-occluded-windows"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhFRTk3NzYxNUJENDIxNTY0NzgyRjMKUldUektkUmJZWGZwamtyaVlIdVQwa3JqU2ZhSWE3SFphYnFxYXYxY3M1dGhYblBlcU1Ea0I3dnlobFBFTQ==",
      "endpoints": [
        "https://github.com/YangZhou91/simple-unrealgamesync/releases/latest/download/latest.json"
      ]
    }
  }
}
