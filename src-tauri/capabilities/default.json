{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "p4", "cmd": "p4", "args": true },
        { "name": "tasklist", "cmd": "tasklist", "args": true },
        { "name": "taskkill", "cmd": "taskkill", "args": true },
        { "name": "cmd", "cmd": "cmd", "args": true }
      ]
    },
    "store:default",
    "dialog:default",
    "fs:default",
    "notification:default"
  ]
}
